
<div id="shopify-section-cart-drawer" class="tt-cart-drawer-wrapper" data-cart-count="{{ cart.item_count }}">
  <div id="tt-cart-drawer" class="tt-cart-drawer">
    <div class="tt-cart-overlay" onclick="closeBagDrawer()"></div>
    <div class="tt-cart-panel">
      
      <div class="tt-cart-header">
        <h2 style="font-size: 22px; text-transform: none; letter-spacing: normal; font-family: var(--font-heading); margin: 0; font-weight: normal;">Your Bag</h2>
        <button class="tt-cart-close" onclick="closeBagDrawer()">&times;</button>
      </div>
      
      <div class="tt-cart-body" id="tt-cart-body-content">
        {% if cart.item_count > 0 %}
          <div class="tt-cart-items">
            {% assign cart_product_ids = "" %}
            {% for item in cart.items %}
              {% assign cart_product_ids = cart_product_ids | append: item.product_id | append: "," %}
              <div class="tt-cart-item" data-key="{{ item.key }}">
                <div class="tt-cart-item-img">
                  {% if item.image %}
                    <img src="{{ item.image | img_url: '200x' }}" alt="{{ item.title | escape }}" loading="lazy">
                  {% endif %}
                </div>
                <div class="tt-cart-item-details">
                  <h4 class="tt-cart-item-title">{{ item.product.title }}</h4>
                  {% unless item.variant.title contains 'Default' %}
                    <p class="tt-cart-variant">{{ item.variant.title }}</p>
                  {% endunless %}
                  <p class="tt-cart-price">{{ item.final_line_price | money }}</p>
                  
                  <div class="tt-cart-qty-wrapper">
                    <div class="tt-cart-qty" style="display: inline-block !important; width: 90px !important; height: 32px !important; border: 1px solid rgba(0,0,0,0.1) !important; background: #fff !important; box-sizing: border-box !important; position: relative;">
    <button type="button" class="tt-qty-btn minus" onclick="changeCartItem(this, '{{ item.key }}', {{ item.quantity | minus: 1 }})" style="position: absolute; left: 0; top: 0; width: 30px !important; height: 30px !important; background: transparent !important; border: none !important; font-size: 18px !important; color: #333 !important; cursor: pointer !important; padding: 0 !important; margin: 0 !important; line-height: 28px !important; text-align: center;">-</button>
    <input type="text" value="{{ item.quantity }}" readonly style="position: absolute; left: 30px; top: 0; width: 30px !important; height: 30px !important; background: transparent !important; border: none !important; border-left: 1px solid rgba(0,0,0,0.1) !important; border-right: 1px solid rgba(0,0,0,0.1) !important; text-align: center !important; font-size: 12px !important; color: #333 !important; padding: 0 !important; margin: 0 !important; outline: none !important; box-sizing: border-box !important; -webkit-appearance: none !important;">
    <button type="button" class="tt-qty-btn plus" onclick="changeCartItem(this, '{{ item.key }}', {{ item.quantity | plus: 1 }})" style="position: absolute; right: 0; top: 0; width: 30px !important; height: 30px !important; background: transparent !important; border: none !important; font-size: 16px !important; color: #333 !important; cursor: pointer !important; padding: 0 !important; margin: 0 !important; line-height: 30px !important; text-align: center;">+</button>
  </div>
                    <a href="#" class="tt-cart-remove" onclick="event.preventDefault(); changeCartItem(this, '{{ item.key }}', 0)">Remove</a>
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
          
          <!-- In-Cart Cross-sells / Add-ons -->
          <div class="tt-cart-addons">
            <h4 class="tt-addons-title">You May Also Like</h4>
            <div class="tt-addons-list">
              {% assign addons_shown = 0 %}
              {% for addon in collections['all'].products %}
                {% assign addon_id_str = addon.id | append: "" %}
                {% unless cart_product_ids contains addon_id_str %}
                  <div class="tt-addon-item">
                    <div class="tt-addon-img">
                      {% if addon.featured_media %}
                        <img src="{{ addon.featured_media | img_url: '150x' }}" alt="{{ addon.title | escape }}" loading="lazy">
                      {% else %}
                        <div class="ayus-placeholder" style="width:100%; height:100%;"></div>
                      {% endif %}
                    </div>
                    <div class="tt-addon-info">
                      <p class="tt-addon-title">{{ addon.title | split: '-' | last | strip | truncate: 50 }}</p>
                      <p class="tt-addon-price">{{ addon.price | money }}</p>
                    </div>
                    <div class="tt-addon-action">
                      <button type="button" class="tt-addon-add-btn" style="background: transparent !important; border: none !important; border-bottom: 1px solid var(--color-accent) !important; font-size: 11px !important; text-transform: uppercase !important; color: var(--color-accent) !important; letter-spacing: 0.1em !important; cursor: pointer !important; padding: 2px 0 !important; font-weight: 600 !important; min-width: 0 !important; width: auto !important; display: inline-block !important; height: auto !important; line-height: 1.2 !important;" onclick="addAddonToCart(this, {{ addon.selected_or_first_available_variant.id }})">Add</button>
                    </div>
                  </div>
                  {% assign addons_shown = addons_shown | plus: 1 %}
                  {% if addons_shown >= 4 %}{% break %}{% endif %}
                {% endunless %}
              {% endfor %}
            </div>
          </div>

        {% else %}
          <div class="tt-cart-empty">
            <p>Your bag is currently empty.</p>
            <a href="/collections/all" class="ayus-btn" style="display:inline-block; background-color: var(--color-accent); color: #fff; border-color: var(--color-accent);" onclick="closeBagDrawer()">Continue Shopping</a>
          </div>
          
          <!-- Add-ons even when empty -->
          <div class="tt-cart-addons">
            <h4 class="tt-addons-title">Discover Favorites</h4>
            <div class="tt-addons-list">
              {% assign addons_shown = 0 %}
              {% for addon in collections['all'].products %}
                <div class="tt-addon-item">
                  <div class="tt-addon-img">
                    {% if addon.featured_media %}
                      <img src="{{ addon.featured_media | img_url: '150x' }}" alt="{{ addon.title | escape }}" loading="lazy">
                    {% else %}
                      <div class="ayus-placeholder" style="width:100%; height:100%;"></div>
                    {% endif %}
                  </div>
                  <div class="tt-addon-info">
                    <p class="tt-addon-title">{{ addon.title | split: '-' | last | strip | truncate: 50 }}</p>
                    <p class="tt-addon-price">{{ addon.price | money }}</p>
                  </div>
                  <div class="tt-addon-action">
                    <button type="button" class="tt-addon-add-btn" style="background: transparent !important; border: none !important; border-bottom: 1px solid var(--color-accent) !important; font-size: 11px !important; text-transform: uppercase !important; color: var(--color-accent) !important; letter-spacing: 0.1em !important; cursor: pointer !important; padding: 2px 0 !important; font-weight: 600 !important; min-width: 0 !important; width: auto !important; display: inline-block !important; height: auto !important; line-height: 1.2 !important;" onclick="addAddonToCart(this, {{ addon.selected_or_first_available_variant.id }})">Add</button>
                  </div>
                </div>
                {% assign addons_shown = addons_shown | plus: 1 %}
                {% if addons_shown >= 4 %}{% break %}{% endif %}
              {% endfor %}
            </div>
          </div>
        {% endif %}
      </div>
      
      {% if cart.item_count > 0 %}
        <div class="tt-cart-footer">
          <div class="tt-cart-subtotal">
            <span>Subtotal</span>
            <span>{{ cart.total_price | money }}</span>
          </div>
          <p class="tt-cart-tax-note">Taxes and shipping calculated at checkout</p>
          <form action="/cart" method="post" id="cart-drawer-form" novalidate>
            <button type="submit" name="checkout" value="Checkout" class="ayus-btn tt-checkout-btn" style="width:100%; background-color: var(--color-accent); color: #fff; border-color: var(--color-accent); white-space: nowrap; font-size: 10px; padding: 12px 5px; letter-spacing: 0.05em;">Proceed to Checkout</button>
          </form>
        </div>
      {% endif %}
      
    </div>
  </div>
</div>

<style>
  .tt-cart-drawer {
    position: fixed; top: 0; left: 0; width: 100vw; height: 100vh;
    z-index: 99999; pointer-events: none; opacity: 0; visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  .tt-cart-drawer.is-open { pointer-events: auto; opacity: 1; visibility: visible; }
  .tt-cart-overlay {
    position: absolute; top: 0; left: 0; width: 100%; height: 100%;
    background: rgba(0,0,0,0.5);
  }
  .tt-cart-panel {
    position: absolute; top: 0; right: -450px;
    width: 400px; max-width: 90vw; height: 100%;
    background: var(--color-background);
    box-shadow: -2px 0 15px rgba(0,0,0,0.1);
    transition: right 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    display: flex; flex-direction: column;
  }
  .tt-cart-drawer.is-open .tt-cart-panel { right: 0; }
  .tt-cart-header { display: flex; justify-content: space-between; align-items: center; padding: 15px 30px; border-bottom: 1px solid rgba(0,0,0,0.05); }
  .tt-cart-header h2 { font-family: var(--font-heading); font-size: 24px; margin: 0; }
  .tt-cart-close { background: transparent; border: none; font-size: 28px; cursor: pointer; color: var(--color-text); }
  .tt-cart-body { flex-grow: 1; overflow-y: auto; overflow-x: hidden; padding: 20px 30px 0 30px; display: flex; flex-direction: column; }
  .tt-cart-items { flex-shrink: 0; }
  .tt-cart-item { display: flex; gap: 20px; margin-bottom: 25px; flex-shrink: 0; }
  .tt-cart-item-img { width: 80px; flex-shrink: 0; }
  .tt-cart-item-img img { width: 100%; height: auto; border: 1px solid var(--color-border); }
  .tt-cart-item-details { flex-grow: 1; display: flex; flex-direction: column; justify-content: center; }
  .tt-cart-item-title { font-family: var(--font-heading); font-size: 16px; margin: 0 0 5px 0; }
  .tt-cart-variant { font-size: 12px; color: #666; margin: 0 0 5px 0; text-transform: uppercase; letter-spacing: 0.05em; }
  .tt-cart-price { font-size: 14px; font-weight: bold; margin: 0 0 10px 0; }
  .tt-cart-qty-wrapper { display: flex; align-items: center; justify-content: space-between; }
  .tt-cart-qty { display: inline-flex !important; border: 1px solid var(--color-border) !important; height: 32px !important; width: 90px !important; background: #fff !important; box-sizing: border-box !important; margin: 0 !important; padding: 0 !important; }
  .tt-cart-qty input { width: 34px !important; height: 100% !important; border: none !important; border-left: 1px solid var(--color-border) !important; border-right: 1px solid var(--color-border) !important; background: transparent !important; text-align: center !important; font-size: 13px !important; padding: 0 !important; margin: 0 !important; color: #333 !important; }
  .tt-cart-qty button { width: 28px !important; height: 100% !important; border: none !important; background: transparent !important; display: flex !important; align-items: center !important; justify-content: center !important; font-size: 16px !important; cursor: pointer !important; padding: 0 !important; margin: 0 !important; color: #333 !important; }
  .tt-cart-remove { font-size: 11px; text-transform: uppercase; color: #888; text-decoration: underline; }
  .tt-cart-footer { padding: 30px; border-top: 1px solid var(--color-border); background: #fff; }
  .tt-cart-subtotal { display: flex; justify-content: space-between; font-size: 18px; font-family: var(--font-heading); margin-bottom: 10px; }
  .tt-cart-tax-note { font-size: 12px; color: #666; margin-bottom: 20px; text-align: center; }
  .tt-cart-empty { text-align: center; padding-top: 50px; }
  .tt-cart-empty p { font-size: 16px; color: #555; margin-bottom: 20px; }
  
  /* Add-ons Styles */
  .tt-cart-addons { margin-top: auto; border-top: 1px solid var(--color-border); padding-top: 25px; padding-bottom: 20px; flex-shrink: 0; }
  .tt-addons-title { font-family: var(--font-heading); font-size: 15px; margin: 0 0 15px 0; text-transform: uppercase; letter-spacing: 0.05em; color: var(--color-text); }
  
  .tt-addons-list { 
    display: flex; 
    gap: 15px; 
    overflow-x: auto; 
    padding-bottom: 10px;
    scrollbar-width: thin;
  }
  .tt-addons-list::-webkit-scrollbar { height: 6px; }
  .tt-addons-list::-webkit-scrollbar-thumb { background: var(--color-accent); border-radius: 6px; }
  .tt-addons-list::-webkit-scrollbar-track { background: #f1f1f1; border-radius: 6px; }
  
  .tt-addon-item { display: flex; flex-direction: column; align-items: center; width: 140px; flex-shrink: 0; padding: 12px; background: #fff; border: 1px solid var(--color-border); text-align: center; }
  
  .tt-addon-img { width: 100%; aspect-ratio: 1; margin-bottom: 10px; }
  .tt-addon-img img { width: 100%; height: 100%; object-fit: cover; display: block; border: 1px solid var(--color-border); }
  
  .tt-addon-info { flex-grow: 1; display: flex; flex-direction: column; justify-content: flex-start; margin-bottom: 10px; width: 100%; }
  .tt-addon-title { font-family: var(--font-body); font-size: 11px; margin: 0 0 5px 0; color: var(--color-text); line-height: 1.4; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; white-space: normal; height: auto; }
  .tt-addon-price { font-size: 12px; margin: 0; color: var(--color-accent); font-weight: bold; }
  
  .tt-addon-action { width: 100%; margin-top: auto; }
  .tt-addon-add-btn { width: 100%; border: none !important; border-bottom: 1px solid rgba(0,0,0,0.2) !important; background-color: transparent !important; padding: 4px 0 !important; font-size: 11px !important; letter-spacing: 0.1em !important; text-transform: uppercase; cursor: pointer; transition: 0.3s; } 
.tt-addon-add-btn:hover { border-bottom-color: var(--color-accent) !important; opacity: 0.7; }
  .tt-addon-add-btn:hover { opacity: 0.8; }
</style>

<script>
  function openBagDrawer() {
    document.getElementById('tt-cart-drawer').classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }
  
  function closeBagDrawer() {
    document.getElementById('tt-cart-drawer').classList.remove('is-open');
    document.body.style.overflow = '';
  }
  
  function changeCartItem(btn, key, qty) {
    if (qty < 0) return;
    
    const itemWrapper = btn.closest('.tt-cart-item');
    const input = itemWrapper ? itemWrapper.querySelector('input') : null;
    
    // 1. Instantly update the input visually (Butter Smooth)
    if (input && qty > 0) {
      input.value = qty;
    }
    
    // If removing the item (qty 0), smoothly fade it out
    if (qty === 0 && itemWrapper) {
      itemWrapper.style.transition = 'opacity 0.3s ease, height 0.3s ease, margin 0.3s ease';
      itemWrapper.style.opacity = '0';
      itemWrapper.style.height = '0px';
      itemWrapper.style.margin = '0px';
      itemWrapper.style.overflow = 'hidden';
    }

    fetch(window.Shopify.routes.root + 'cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: key, quantity: qty })
    })
    .then(response => response.json())
    .then(cart => {
       // 2. Parse the cart JSON and update the DOM directly without refreshing the whole section
       
       // Update overall cart badge counts
       const countElements = document.querySelectorAll('.ayus-cart-link .tt-cart-badge');
       countElements.forEach(el => el.innerText = cart.item_count);
       
       if (cart.item_count === 0) {
         // If cart is completely empty, trigger a full HTML refresh to show the empty state graphic
         refreshBagDrawer();
         return;
       }
       
       // Format money helper (Assuming Rs. format)
       const formatMoney = (cents) => 'Rs. ' + (cents / 100).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ",");
       
       // Update Subtotal
       const subtotalEl = document.querySelector('.tt-cart-subtotal span:last-child');
       if (subtotalEl) {
         subtotalEl.innerText = formatMoney(cart.total_price);
       }
       
       // Update individual line item prices
       if (qty > 0 && itemWrapper) {
         const lineItem = cart.items.find(i => i.key === key);
         if (lineItem) {
           const priceEl = itemWrapper.querySelector('.tt-cart-price');
           if (priceEl) {
             priceEl.innerText = formatMoney(lineItem.final_line_price);
           }
         }
       } else if (qty === 0 && itemWrapper) {
         // Remove it from the DOM completely now that the fade out is done
         setTimeout(() => itemWrapper.remove(), 300);
       }
    })
    .catch(error => {
       console.error('Error updating cart:', error);
       // Revert UI on failure
       refreshBagDrawer();
    });
  }

  function addAddonToCart(btn, variantId) {
    const originalText = btn.dataset.originalText || btn.innerText;
    btn.dataset.originalText = originalText;
    /* btn.innerText = "Adding..."; */ btn.style.opacity = "0.5";
    btn.disabled = true;
    openBagDrawer();

    fetch(window.Shopify.routes.root + 'cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 })
    })
    .then(res => {
      if (!res.ok) throw new Error('Add to cart failed');
      return res.json();
    })
    .then(() => {
      refreshBagDrawer();
    })
    .catch(err => {
      console.error(err);
      /* btn.innerText = originalText; */ btn.style.opacity = "1";
      btn.disabled = false;
    })
    .finally(() => {
      setTimeout(() => {
        if (btn && btn.isConnected) {
          /* btn.innerText = originalText; */ btn.style.opacity = "1";
          btn.disabled = false;
        }
      }, 450);
    });
  }
  
  function refreshBagDrawer() {
    fetch(window.location.pathname + '?section_id=ayus-cart-drawer')
    .then(res => res.text())
    .then(html => {
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, 'text/html');
      const newDrawerWrapper = doc.getElementById('shopify-section-ayus-cart-drawer');
      
      if(newDrawerWrapper) {
        document.getElementById('shopify-section-ayus-cart-drawer').innerHTML = newDrawerWrapper.innerHTML;
        document.getElementById('tt-cart-drawer').classList.add('is-open');
        
        const newCount = document.getElementById('shopify-section-cart-drawer')?.getAttribute('data-cart-count');
        const countElements = document.querySelectorAll('.ayus-cart-link');
        countElements.forEach(el => {
          if(el.querySelector('.tt-cart-badge')) { el.querySelector('.tt-cart-badge').innerText = newCount || document.querySelector('.tt-cart-drawer-wrapper').getAttribute('data-cart-count'); }
        });
      }
    });
  }

  document.addEventListener('DOMContentLoaded', function() {
    document.addEventListener('submit', function(e) {
      const form = e.target;
      if (form.action && form.action.indexOf('/cart/add') !== -1) {
        e.preventDefault();
        
        const submitBtn = form.querySelector('[type="submit"]');
        if(!submitBtn) return;
        const originalText = submitBtn.innerText;
        submitBtn.innerText = 'Adding...';
        submitBtn.disabled = true;

        fetch(window.Shopify.routes.root + 'cart/add.js', {
          method: 'POST',
          body: new FormData(form)
        })
        .then(response => response.json())
        .then(data => {
          refreshBagDrawer();
          openBagDrawer();
          submitBtn.innerText = originalText;
          submitBtn.disabled = false;
        })
        .catch((error) => {
          console.error('Error:', error);
          submitBtn.innerText = originalText;
          submitBtn.disabled = false;
        });
      }
    });

    document.addEventListener('click', function(e) {
      // Find the closest ancestor that matches our cart link class
      const cartLink = e.target.closest('.ayus-cart-link');
      if (cartLink) {
        e.preventDefault();
        openBagDrawer();
      }
    });
  });
</script>

{% schema %}
{
  "name": "Cart Drawer",
  "settings": []
}
{% endschema %}



<!-- Quick Add Modal -->
<div class="tt-qa-overlay" id="tt-qa-overlay" onclick="closeQuickAdd()"></div>
<div class="tt-qa-drawer" id="tt-qa-drawer">
  <button class="tt-qa-close" onclick="closeQuickAdd()">&times;</button>
  <div class="tt-qa-header-product" id="tt-qa-header-product">
    <!-- Populated by JS -->
  </div>
  <div class="tt-qa-body" id="tt-qa-variants">
    <div style="text-align:center; padding: 20px; font-size: 13px; text-transform: uppercase; letter-spacing: 0.1em; color: #888;">Loading...</div>
  </div>
</div>
<style>
  .tt-qa-overlay { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background: rgba(0,0,0,0.5); z-index: 9999998; opacity: 0; visibility: hidden; transition: 0.3s; }
  .tt-qa-overlay.active { opacity: 1; visibility: visible; }
  .tt-qa-drawer { position: fixed; bottom: -100%; left: 0; width: 100%; background: #faf8f5; z-index: 9999999; padding: 30px 24px; border-top-left-radius: 20px; border-top-right-radius: 20px; transition: 0.4s cubic-bezier(0.16, 1, 0.3, 1); box-shadow: 0 -5px 20px rgba(0,0,0,0.1); max-height: 85vh; overflow-y: auto; display: flex; flex-direction: column; }
  .tt-qa-drawer.active { bottom: 0; }
  
  .tt-qa-close { position: absolute; top: 15px; right: 15px; background: transparent; border: none; font-size: 32px; font-weight: 300; width: 32px; height: 32px; display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--color-text); padding: 0; margin: 0; line-height: 1; z-index: 2; box-shadow: none; border-radius: 0; }
  
  .tt-qa-header-product { display: flex; gap: 20px; align-items: flex-start; margin-bottom: 25px; padding-bottom: 25px; border-bottom: 1px solid rgba(0,0,0,0.05); padding-right: 20px; }
  .tt-qa-prod-img { width: 90px; height: 90px; object-fit: cover; border: 1px solid var(--color-border); border-radius: 4px; }
  .tt-qa-prod-info { flex-grow: 1; }
  .tt-qa-prod-vendor { font-size: 11px; text-transform: uppercase; letter-spacing: 0.15em; color: #777; margin-bottom: 6px; display: block; }
  .tt-qa-prod-title { font-family: var(--font-body); font-size: 18px; margin: 0 0 8px 0; color: var(--color-text); line-height: 1.2; font-weight: bold; }
  .tt-qa-prod-desc { font-size: 13px; color: #666; margin: 0; line-height: 1.4; }

  .tt-qa-variant-row { display: flex; align-items: center; justify-content: space-between; padding: 18px 0; border-bottom: 1px solid rgba(0,0,0,0.05); cursor: pointer; transition: 0.3s; }
  .tt-qa-variant-row:last-child { border-bottom: none; padding-bottom: 0; }
  .tt-qa-variant-row:hover { opacity: 0.7; }
  .tt-qa-v-title { font-family: var(--font-body); font-size: 15px; letter-spacing: 0.05em; color: var(--color-text); }
  .tt-qa-v-price { font-family: var(--font-body); font-size: 15px; color: var(--color-text); margin-left: auto; margin-right: 20px; }
  .tt-qa-v-add { font-size: 12px; font-weight: bold; text-transform: uppercase; letter-spacing: 0.1em; color: #fff; background: var(--color-accent); display: flex; align-items: center; justify-content: center; padding: 8px 16px; border-radius: 4px; border: 1px solid var(--color-accent); }
</style>
<script>
  function closeQuickAdd() {
    document.getElementById('tt-qa-overlay').classList.remove('active');
    document.getElementById('tt-qa-drawer').classList.remove('active');
  }
  function openQuickAddModal(handle) {
    document.getElementById('tt-qa-header-product').innerHTML = '';
    document.getElementById('tt-qa-variants').innerHTML = '<div style="text-align:center; padding: 20px; font-size: 13px; text-transform: uppercase; letter-spacing: 0.1em; color: #888;">Loading...</div>';
    document.getElementById('tt-qa-overlay').classList.add('active');
    document.getElementById('tt-qa-drawer').classList.add('active');
    
    fetch('/products/' + handle + '.js')
      .then(r => r.json())
      .then(product => {
        // Build Header
        let imgUrl = product.featured_image || '';
        let vendor = product.vendor || 'Tulsi Tales';
        let title = product.title.split('-').pop().trim();
        // Strip HTML from description for a short excerpt
        let descHtml = product.description || '';
        let descText = descHtml;
        
        let headerHtml = '';
        if(imgUrl) {
          headerHtml += '<img src="' + imgUrl + '" class="tt-qa-prod-img" alt="' + title + '">';
        }
        headerHtml += '<div class="tt-qa-prod-info">';
        headerHtml += '<span class="tt-qa-prod-vendor">' + vendor + '</span>';
        headerHtml += '<h4 class="tt-qa-prod-title">' + title + '</h4>';
        if(descText) {
          headerHtml += '<div class="tt-qa-prod-desc">' + descText + '</div>';
        }
        headerHtml += '</div>';
        
        document.getElementById('tt-qa-header-product').innerHTML = headerHtml;

        // Build Variants
        let vHtml = '';
        product.variants.forEach(v => {
          let price = (v.price / 100).toFixed(2);
          vHtml += '<div class="tt-qa-variant-row" onclick="addVariantToCart(' + v.id + ')">';
          vHtml += '<span class="tt-qa-v-title">' + v.title + '</span>';
          vHtml += '<span class="tt-qa-v-price">Rs. ' + price + '</span>';
          vHtml += '<span class="tt-qa-v-add">ADD</span>';
          vHtml += '</div>';
        });
        document.getElementById('tt-qa-variants').innerHTML = vHtml;
      });
  }
  function addVariantToCart(id) {
    closeQuickAdd();
    openBagDrawer();
    fetch(window.Shopify.routes.root + 'cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: id, quantity: 1 })
    }).then(() => refreshBagDrawer());
  }
</script>

