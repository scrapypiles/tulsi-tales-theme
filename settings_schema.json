[
  {
    "name": "theme_info",
    "theme_name": "Ayus AI Prototype",
    "theme_version": "1.0.0",
    "theme_author": "OpenClaw",
    "theme_documentation_url": "https:\/\/github.com\/openclaw",
    "theme_support_url": "https:\/\/github.com\/openclaw"
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_bg",
        "label": "Background (Cream)",
        "default": "#FAF8F5"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Main Text",
        "default": "#2C2C2C"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent \/ Primary (Sage Green)",
        "default": "#4A5D4E"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Borders & Dividers",
        "default": "#EAE5D9"
      },
      {
        "type": "color",
        "id": "color_button_text",
        "label": "Button Text",
        "default": "#FFFFFF"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading Font",
        "default": "playfair_display_n4"
      },
      {
        "type": "range",
        "id": "heading_base_size",
        "min": 18,
        "max": 64,
        "step": 1,
        "unit": "px",
        "label": "Base Heading Size",
        "default": 36
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body Font",
        "default": "lato_n4"
      },
      {
        "type": "range",
        "id": "body_base_size",
        "min": 10,
        "max": 24,
        "step": 1,
        "unit": "px",
        "label": "Base Body Size",
        "default": 14
      }
    ]
  },
  {
    "name": "Layout & Styling",
    "settings": [
      {
        "type": "range",
        "id": "section_padding",
        "min": 20,
        "max": 150,
        "step": 5,
        "unit": "px",
        "label": "Global Section Padding",
        "default": 80
      },
      {
        "type": "range",
        "id": "border_radius",
        "min": 0,
        "max": 40,
        "step": 1,
        "unit": "px",
        "label": "Global Border Radius",
        "default": 0
      }
    ]
  },
  {
    "name": "Advanced Typography",
    "settings": [
      {
        "type": "checkbox",
        "id": "enable_advanced_typography",
        "label": "Enable advanced typography overrides",
        "default": false
      },
      {
        "type": "range",
        "id": "type_h1_desktop",
        "min": 24,
        "max": 96,
        "step": 2,
        "unit": "px",
        "label": "H1 desktop size",
        "default": 48
      },
      {
        "type": "range",
        "id": "type_h1_mobile",
        "min": 20,
        "max": 64,
        "step": 2,
        "unit": "px",
        "label": "H1 mobile size",
        "default": 32
      },
      {
        "type": "range",
        "id": "type_h2_desktop",
        "min": 20,
        "max": 72,
        "step": 2,
        "unit": "px",
        "label": "H2 desktop size",
        "default": 36
      },
      {
        "type": "range",
        "id": "type_h2_mobile",
        "min": 18,
        "max": 48,
        "step": 2,
        "unit": "px",
        "label": "H2 mobile size",
        "default": 28
      },
      {
        "type": "range",
        "id": "type_h3_desktop",
        "min": 16,
        "max": 48,
        "step": 2,
        "unit": "px",
        "label": "H3 desktop size",
        "default": 24
      },
      {
        "type": "range",
        "id": "type_h3_mobile",
        "min": 14,
        "max": 36,
        "step": 2,
        "unit": "px",
        "label": "H3 mobile size",
        "default": 20
      },
      {
        "type": "range",
        "id": "type_body_desktop",
        "min": 12,
        "max": 24,
        "step": 1,
        "unit": "px",
        "label": "Body desktop size",
        "default": 14
      },
      {
        "type": "range",
        "id": "type_body_mobile",
        "min": 12,
        "max": 22,
        "step": 1,
        "unit": "px",
        "label": "Body mobile size",
        "default": 14
      },
      {
        "type": "range",
        "id": "type_heading_line_height",
        "min": 100,
        "max": 200,
        "step": 5,
        "label": "Heading line height (%)",
        "default": 120
      },
      {
        "type": "range",
        "id": "type_body_line_height",
        "min": 100,
        "max": 240,
        "step": 5,
        "label": "Body line height (%)",
        "default": 170
      },
      {
        "type": "range",
        "id": "type_heading_tracking",
        "min": -10,
        "max": 100,
        "step": 5,
        "unit": "px",
        "label": "Heading letter spacing (0.1px steps)",
        "default": 0
      },
      {
        "type": "range",
        "id": "type_body_tracking",
        "min": -10,
        "max": 50,
        "step": 5,
        "unit": "px",
        "label": "Body letter spacing (0.1px steps)",
        "default": 0
      },
      {
        "type": "select",
        "id": "type_heading_transform",
        "label": "Heading text transform",
        "options": [
          { "value": "none", "label": "Normal" },
          { "value": "uppercase", "label": "Uppercase" },
          { "value": "capitalize", "label": "Capitalize" }
        ],
        "default": "none"
      },
      {
        "type": "select",
        "id": "type_body_transform",
        "label": "Body text transform",
        "options": [
          { "value": "none", "label": "Normal" },
          { "value": "uppercase", "label": "Uppercase" },
          { "value": "capitalize", "label": "Capitalize" }
        ],
        "default": "none"
      },
      {
        "type": "select",
        "id": "type_heading_style",
        "label": "Heading font style",
        "options": [
          { "value": "normal", "label": "Normal" },
          { "value": "italic", "label": "Italic" }
        ],
        "default": "normal"
      },
      {
        "type": "select",
        "id": "type_body_style",
        "label": "Body font style",
        "options": [
          { "value": "normal", "label": "Normal" },
          { "value": "italic", "label": "Italic" }
        ],
        "default": "normal"
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      {
        "type": "image_picker",
        "id": "share_image",
        "label": "Social sharing image",
        "info": "Shown when sharing links on Facebook, WhatsApp, etc. (1200 x 630px recommended)"
      }
    ]
  }
]
