                const newLoadMore = html.querySelector('.tt-load-more-btn');
                if (newLoadMore) {
                  btn.setAttribute('data-url', newLoadMore.getAttribute('data-url'));
                  btn.innerText = originalText;
                  btn.disabled = false;
                } else {
                  loadMoreWrapper.remove();
                }
              })
              .catch(e => {
                console.error(e);
                btn.innerText = "Failed. Try Again.";
                btn.disabled = false;
              });
          }
      </script>

</section>






{% schema %}
{
  "name": "Collection Grid & Filters",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Default Banner Image"
    },
    {
      "type": "textarea",
      "id": "concerns",
      "label": "Concern Filter Options",
      "default": "Immunity, Digestion, Skin Care, Hair Care, Stress Relief, Detox, Pain Relief, Respiratory, Sleep"
    }
  ]
}
{% endschema %}

<script>

// INFINITE SCROLL OBSERVER
document.addEventListener("DOMContentLoaded", function() {
  const trigger = document.querySelector('.tt-infinite-scroll-trigger');
  if (!trigger) return;
  
  const observer = new IntersectionObserver((entries) => {
    if (entries[0].isIntersecting) {
      loadMoreProducts(trigger);
    }
  }, { rootMargin: "0px 0px 400px 0px" });
  
  observer.observe(trigger);
});

// MODIFIED LOAD MORE LOGIC FOR INFINITE
window.loadMoreProducts = function(button) {
  if(button.classList.contains('loading')) return;
  const url = button.getAttribute('data-url');
  if(!url) return;
  
  button.classList.add('loading');
  
  fetch(url)
    .then(res => res.text())
    .then(data => {
      const parser = new DOMParser();
      const doc = parser.parseFromString(data, 'text/html');
      const newItems = doc.querySelectorAll('.ayus-product-card');
      const grid = document.getElementById('CollectionProductGrid');
      
      // We must insert the new items BEFORE the infinite trigger, not just append to grid
      // So we append to the grid, but the trigger might be the last child. 
      // Actually, since trigger is at the bottom, just appending child before trigger works.
      const triggerElem = document.querySelector('.tt-infinite-scroll-trigger');
      
      newItems.forEach(item => {
        grid.insertBefore(item, triggerElem);
      });
      
      const newNext = doc.querySelector('.tt-infinite-scroll-trigger');
      if (newNext) {
        button.setAttribute('data-url', newNext.getAttribute('data-url'));
        button.classList.remove('loading');
      } else {
        button.style.display = 'none'; // No more pages
      }
    });
}

</script>
