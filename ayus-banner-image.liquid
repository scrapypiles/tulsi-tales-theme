{%- style -%}
  #shopify-section-{{ section.id }} .tt-image-banner {
    position: relative;
    color: {{ section.settings.text_color }};
    min-height: {{ section.settings.min_height }}px;
    display: flex;
    align-items: center;
    justify-content: {{ section.settings.content_position }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    background-color: {{ section.settings.fallback_color }};
    {% if section.settings.image != blank %}
      background-image: url('{{ section.settings.image | image_url: width: 2400 }}');
      background-size: cover;
      background-position: {{ section.settings.background_position }};
      background-repeat: no-repeat;
    {% endif %}
  }
  #shopify-section-{{ section.id }} .tt-image-banner::before {
    content: "";
    position: absolute;
    inset: 0;
    background: {{ section.settings.overlay_color }};
    opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }
  #shopify-section-{{ section.id }} .tt-image-banner-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: {{ section.settings.content_width }}px;
    margin: 0 auto;
    text-align: {{ section.settings.text_align }};
  }
  #shopify-section-{{ section.id }} .tt-image-banner-eyebrow {
    display: block;
    margin-bottom: 14px;
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  #shopify-section-{{ section.id }} .tt-image-banner .tt-image-banner-heading {
    margin: 0 0 14px;
    font-family: var(--font-heading);
    font-size: {{ section.settings.heading_size }}px;
    line-height: {{ section.settings.heading_line_height | divided_by: 100.0 }};
    letter-spacing: {{ section.settings.heading_tracking | divided_by: 10.0 }}px;
    color: inherit;
  }
  #shopify-section-{{ section.id }} .tt-image-banner-copy,
  #shopify-section-{{ section.id }} .tt-image-banner-copy p {
    margin: 0;
    font-family: var(--font-body);
    font-size: {{ section.settings.body_size }}px;
    line-height: {{ section.settings.body_line_height | divided_by: 100.0 }};
    letter-spacing: {{ section.settings.body_tracking | divided_by: 10.0 }}px;
    color: inherit;
  }
  #shopify-section-{{ section.id }} .tt-image-banner-actions {
    margin-top: 28px;
  }
  @media (max-width: 850px) {
    #shopify-section-{{ section.id }} .tt-image-banner {
      min-height: {{ section.settings.mobile_min_height }}px;
      padding: {{ section.settings.mobile_padding_top }}px 20px {{ section.settings.mobile_padding_bottom }}px;
    }
    #shopify-section-{{ section.id }} .tt-image-banner .tt-image-banner-heading {
      font-size: {{ section.settings.mobile_heading_size }}px;
    }
    #shopify-section-{{ section.id }} .tt-image-banner-copy,
    #shopify-section-{{ section.id }} .tt-image-banner-copy p {
      font-size: {{ section.settings.mobile_body_size }}px;
    }
  }
{%- endstyle -%}

{% if section.settings.show_section %}
<section class="tt-image-banner">
  <div class="tt-image-banner-inner">
    {% if section.settings.eyebrow != blank %}
      <span class="tt-image-banner-eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}
    {% if section.settings.heading != blank %}
      <{{ section.settings.heading_tag }} class="tt-image-banner-heading">{{ section.settings.heading }}</{{ section.settings.heading_tag }}>
    {% endif %}
    {% if section.settings.body != blank %}
      <div class="tt-image-banner-copy">{{ section.settings.body }}</div>
    {% endif %}
    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <div class="tt-image-banner-actions">
        <a href="{{ section.settings.button_link }}" class="ayus-btn">{{ section.settings.button_label }}</a>
      </div>
    {% endif %}
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "Ayus Banner Image",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show section", "default": true },
    { "type": "image_picker", "id": "image", "label": "Background image" },
    { "type": "color", "id": "fallback_color", "label": "Fallback background color", "default": "#2c2c2c" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#ffffff" },
    { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "label": "Overlay opacity", "default": 35 },
    { "type": "select", "id": "background_position", "label": "Background position", "options": [
      { "value": "center center", "label": "Center" },
      { "value": "center top", "label": "Top" },
      { "value": "center bottom", "label": "Bottom" },
      { "value": "left center", "label": "Left" },
      { "value": "right center", "label": "Right" }
    ], "default": "center center" },
    { "type": "select", "id": "content_position", "label": "Vertical content position", "options": [
      { "value": "flex-start", "label": "Top" },
      { "value": "center", "label": "Middle" },
      { "value": "flex-end", "label": "Bottom" }
    ], "default": "center" },
    { "type": "select", "id": "text_align", "label": "Text alignment", "options": [
      { "value": "left", "label": "Left" },
      { "value": "center", "label": "Center" },
      { "value": "right", "label": "Right" }
    ], "default": "center" },
    { "type": "range", "id": "content_width", "min": 480, "max": 1400, "step": 20, "unit": "px", "label": "Content width", "default": 900 },
    { "type": "range", "id": "min_height", "min": 200, "max": 900, "step": 20, "unit": "px", "label": "Desktop min height", "default": 420 },
    { "type": "range", "id": "mobile_min_height", "min": 160, "max": 700, "step": 20, "unit": "px", "label": "Mobile min height", "default": 320 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 200, "step": 2, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 200, "step": 2, "unit": "px", "label": "Padding bottom", "default": 80 },
    { "type": "range", "id": "mobile_padding_top", "min": 0, "max": 160, "step": 2, "unit": "px", "label": "Mobile padding top", "default": 56 },
    { "type": "range", "id": "mobile_padding_bottom", "min": 0, "max": 160, "step": 2, "unit": "px", "label": "Mobile padding bottom", "default": 56 },
    { "type": "range", "id": "heading_size", "min": 20, "max": 90, "step": 2, "unit": "px", "label": "Heading size", "default": 48 },
    { "type": "range", "id": "mobile_heading_size", "min": 18, "max": 64, "step": 2, "unit": "px", "label": "Mobile heading size", "default": 32 },
    { "type": "range", "id": "body_size", "min": 12, "max": 28, "step": 1, "unit": "px", "label": "Body size", "default": 18 },
    { "type": "range", "id": "mobile_body_size", "min": 12, "max": 24, "step": 1, "unit": "px", "label": "Mobile body size", "default": 15 },
    { "type": "range", "id": "heading_line_height", "min": 100, "max": 200, "step": 5, "label": "Heading line height (%)", "default": 120 },
    { "type": "range", "id": "body_line_height", "min": 100, "max": 240, "step": 5, "label": "Body line height (%)", "default": 170 },
    { "type": "range", "id": "heading_tracking", "min": -10, "max": 100, "step": 5, "unit": "px", "label": "Heading letter spacing (0.1px steps)", "default": 0 },
    { "type": "range", "id": "body_tracking", "min": -10, "max": 50, "step": 5, "unit": "px", "label": "Body letter spacing (0.1px steps)", "default": 0 },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Campaign" },
    { "type": "select", "id": "heading_tag", "label": "Heading tag", "options": [
      { "value": "h1", "label": "H1" },
      { "value": "h2", "label": "H2" },
      { "value": "h3", "label": "H3" },
      { "value": "p", "label": "Paragraph" }
    ], "default": "h2" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A flexible image banner for future launches" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Use this section later for launches, seasonal edits, collection storytelling, or editorial campaign moments.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Learn more" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [
    { "name": "Ayus Banner Image" }
  ]
}
{% endschema %}
