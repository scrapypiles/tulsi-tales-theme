{%- style -%}
  #shopify-section-{{ section.id }} .tt-basic-banner {
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    text-align: {{ section.settings.text_align }};
    border-top: {% if section.settings.show_top_border %}1px solid var(--color-border){% else %}none{% endif %};
    border-bottom: {% if section.settings.show_bottom_border %}1px solid var(--color-border){% else %}none{% endif %};
  }
  #shopify-section-{{ section.id }} .tt-basic-banner-inner {
    max-width: {{ section.settings.content_width }}px;
    margin: 0 auto;
  }
  #shopify-section-{{ section.id }} .tt-basic-banner-eyebrow {
    display: block;
    margin-bottom: 14px;
    font-family: var(--font-body);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    opacity: 0.9;
  }
  #shopify-section-{{ section.id }} .tt-basic-banner .tt-basic-banner-heading {
    margin: 0 0 14px;
    font-family: var(--font-heading);
    font-size: {{ section.settings.heading_size }}px;
    line-height: {{ section.settings.heading_line_height | divided_by: 100.0 }};
    letter-spacing: {{ section.settings.heading_tracking | divided_by: 10.0 }}px;
    color: inherit;
  }
  #shopify-section-{{ section.id }} .tt-basic-banner-copy,
  #shopify-section-{{ section.id }} .tt-basic-banner-copy p {
    margin: 0;
    font-family: var(--font-body);
    font-size: {{ section.settings.body_size }}px;
    line-height: {{ section.settings.body_line_height | divided_by: 100.0 }};
    letter-spacing: {{ section.settings.body_tracking | divided_by: 10.0 }}px;
    color: inherit;
  }
  #shopify-section-{{ section.id }} .tt-basic-banner-actions {
    margin-top: 28px;
  }
  @media (max-width: 850px) {
    #shopify-section-{{ section.id }} .tt-basic-banner {
      padding: {{ section.settings.mobile_padding_top }}px 20px {{ section.settings.mobile_padding_bottom }}px;
    }
    #shopify-section-{{ section.id }} .tt-basic-banner .tt-basic-banner-heading {
      font-size: {{ section.settings.mobile_heading_size }}px;
    }
    #shopify-section-{{ section.id }} .tt-basic-banner-copy,
    #shopify-section-{{ section.id }} .tt-basic-banner-copy p {
      font-size: {{ section.settings.mobile_body_size }}px;
    }
  }
{%- endstyle -%}

{% if section.settings.show_section %}
<section class="tt-basic-banner">
  <div class="tt-basic-banner-inner">
    {% if section.settings.eyebrow != blank %}
      <span class="tt-basic-banner-eyebrow">{{ section.settings.eyebrow }}</span>
    {% endif %}
    {% if section.settings.heading != blank %}
      <{{ section.settings.heading_tag }} class="tt-basic-banner-heading">{{ section.settings.heading }}</{{ section.settings.heading_tag }}>
    {% endif %}
    {% if section.settings.body != blank %}
      <div class="tt-basic-banner-copy">{{ section.settings.body }}</div>
    {% endif %}
    {% if section.settings.button_label != blank and section.settings.button_link != blank %}
      <div class="tt-basic-banner-actions">
        <a href="{{ section.settings.button_link }}" class="ayus-btn">{{ section.settings.button_label }}</a>
      </div>
    {% endif %}
  </div>
</section>
{% endif %}

{% schema %}
{
  "name": "Ayus Banner Basic",
  "settings": [
    { "type": "checkbox", "id": "show_section", "label": "Show section", "default": true },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#faf8f5" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#2c2c2c" },
    { "type": "select", "id": "text_align", "label": "Text alignment", "options": [
      { "value": "left", "label": "Left" },
      { "value": "center", "label": "Center" },
      { "value": "right", "label": "Right" }
    ], "default": "center" },
    { "type": "range", "id": "content_width", "min": 480, "max": 1400, "step": 20, "unit": "px", "label": "Content width", "default": 900 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 200, "step": 2, "unit": "px", "label": "Padding top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 200, "step": 2, "unit": "px", "label": "Padding bottom", "default": 80 },
    { "type": "range", "id": "mobile_padding_top", "min": 0, "max": 160, "step": 2, "unit": "px", "label": "Mobile padding top", "default": 56 },
    { "type": "range", "id": "mobile_padding_bottom", "min": 0, "max": 160, "step": 2, "unit": "px", "label": "Mobile padding bottom", "default": 56 },
    { "type": "range", "id": "heading_size", "min": 20, "max": 80, "step": 2, "unit": "px", "label": "Heading size", "default": 40 },
    { "type": "range", "id": "mobile_heading_size", "min": 18, "max": 56, "step": 2, "unit": "px", "label": "Mobile heading size", "default": 30 },
    { "type": "range", "id": "body_size", "min": 12, "max": 28, "step": 1, "unit": "px", "label": "Body size", "default": 16 },
    { "type": "range", "id": "mobile_body_size", "min": 12, "max": 24, "step": 1, "unit": "px", "label": "Mobile body size", "default": 15 },
    { "type": "range", "id": "heading_line_height", "min": 100, "max": 200, "step": 5, "label": "Heading line height (%)", "default": 120 },
    { "type": "range", "id": "body_line_height", "min": 100, "max": 240, "step": 5, "label": "Body line height (%)", "default": 170 },
    { "type": "range", "id": "heading_tracking", "min": -10, "max": 100, "step": 5, "unit": "px", "label": "Heading letter spacing (0.1px steps)", "default": 0 },
    { "type": "range", "id": "body_tracking", "min": -10, "max": 50, "step": 5, "unit": "px", "label": "Body letter spacing (0.1px steps)", "default": 0 },
    { "type": "checkbox", "id": "show_top_border", "label": "Show top border", "default": false },
    { "type": "checkbox", "id": "show_bottom_border", "label": "Show bottom border", "default": false },
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Banner" },
    { "type": "select", "id": "heading_tag", "label": "Heading tag", "options": [
      { "value": "h1", "label": "H1" },
      { "value": "h2", "label": "H2" },
      { "value": "h3", "label": "H3" },
      { "value": "p", "label": "Paragraph" }
    ], "default": "h2" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A flexible text banner for future storytelling" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Use this for announcements, campaign messages, collection intros, or supporting editorial copy.</p>" },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Explore" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [
    { "name": "Ayus Banner Basic" }
  ]
}
{% endschema %}
