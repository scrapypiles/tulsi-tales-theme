<footer class="site-footer" style="padding: 100px 20px 40px; background-color: #F7F5F0; color: #2C2A29; font-family: var(--font-body); border-top: 1px solid #EAE5D9;">
  <div style="max-width: 1200px; margin: 0 auto; display: flex; flex-wrap: wrap; justify-content: space-between; gap: 40px;">
    
    <!-- Column 1: Logo & Text -->
    <div style="flex: 1; min-width: 250px;">
      <div style="margin-bottom: 20px;">
        {%- assign logo_url = "tulsi-tales-logo.png" -%}
        {%- if logo_url != blank -%}
          <img src="{{ logo_url | asset_url }}" alt="Tulsi Tales Logo" style="max-width: 180px; height: auto;" />
        {%- elsif section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 120 }}" alt="Tulsi Tales Logo" style="max-width: 180px; height: auto;" />
        {%- else -%}
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#2C2A29" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22c0-5 2-8 5-11-3 0-5 2-5 5 0-3-2-5-5-5 3 3 5 6 5 11z"></path>
            <path d="M12 22V12"></path>
          </svg>
        {%- endif -%}
      </div>
      <p style="font-size: 13px; line-height: 2; color: #555;">Rooted in Ayurvedic wisdom.<br>Crafted for modern rituals.</p>
    </div>
    
    <!-- Column 2: Main Links -->
    <div style="flex: 1; min-width: 250px;">
      <h4 style="font-family: var(--font-heading); font-weight: 300; letter-spacing: 2px; text-transform: uppercase; font-size: 11px; margin-bottom: 20px; color: #111;">Explore</h4>
      <ul style="list-style: none; padding: 0; font-size: 12px; line-height: 2.5; letter-spacing: 1px; text-transform: uppercase;">
        <li><a href="/collections/all" style="text-decoration: none; color: #555;">All Products</a></li>
        <li><a href="/pages/our-story" style="text-decoration: none; color: #555;">Our Story</a></li>
        <li><a href="/pages/contact" style="text-decoration: none; color: #555;">Contact Us</a></li>
      </ul>
    </div>
    
    <!-- Column 3: Contact & Newsletter -->
    <div style="flex: 1; min-width: 250px;">
      <h4 style="font-family: var(--font-heading); font-weight: 300; letter-spacing: 2px; text-transform: uppercase; font-size: 11px; margin-bottom: 20px; color: #111;">Contact & Join</h4>
      <p style="font-size: 13px; line-height: 1.6; color: #555; margin-bottom: 20px;">
        Email: hello@tulsitales.com<br>
        Phone: +91 800 000 0000
      </p>
      
      {% form 'customer', id: 'ContactFooter', class: 'footer__newsletter newsletter-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div style="display: flex; border-bottom: 1px solid #111; padding-bottom: 5px; max-width: 300px;">
          <input
            id="NewsletterForm--{{ section.id }}"
            type="email"
            name="contact[email]"
            class="field__input"
            value="{{ form.email }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            placeholder="ENTER YOUR EMAIL"
            style="border: none; background: transparent; width: 100%; font-family: var(--font-body); font-size: 11px; letter-spacing: 0.1em; color: #111; outline: none;"
            required
          >
          <button type="submit" name="commit" id="Subscribe" style="background: transparent; border: none; font-size: 16px; cursor: pointer; color: #111;">&rarr;</button>
        </div>
        {%- if form.posted_successfully? -%}
          <p style="font-size: 11px; color: green; margin-top: 10px; text-transform: uppercase; letter-spacing: 0.05em;">Thanks for subscribing!</p>
        {%- endif -%}
      {% endform %}
    </div>
  </div>

  <!-- Bottom Section -->
  <div style="max-width: 1200px; margin: 60px auto 0; padding-top: 30px; border-top: 1px solid var(--color-border); display: flex; flex-direction: column; align-items: center; gap: 20px;">
    
    <!-- Policy Links -->
    <div style="display: flex; gap: 30px; justify-content: center; flex-wrap: wrap;">
      <a href="/pages/terms" style="font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none; color: #888;">Terms of Service</a>
      <a href="/pages/policy" style="font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none; color: #888;">Privacy Policy</a>
      <a href="/pages/refund" style="font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none; color: #888;">Refund Policy</a>
      <a href="/pages/shipping" style="font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none; color: #888;">Shipping Policy</a>
    </div>

    <!-- Localization -->
    {%- if localization.available_countries.size > 1 or localization.available_languages.size > 1 -%}
      {%- form 'localization', id: 'AyusFooterLocalizationForm', class: 'ayus-localization-form' -%}
        <div style="display: flex; gap: 15px; justify-content: center; align-items: center; flex-wrap: wrap;">
          {%- if localization.available_countries.size > 1 -%}
            <div class="ayus-loc-wrapper">
              <select name="country_code" onchange="this.form.submit()" style="background: transparent; border: 1px solid var(--color-border); padding: 10px 15px; font-family: var(--font-body); font-size: 11px; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-text); border-radius: 0; cursor: pointer; outline: none; -webkit-appearance: none; -moz-appearance: none; appearance: none; text-align: center; padding-right: 25px; background-image: url('data:image/svg+xml;utf8,<svg width=\"10\" height=\"6\" viewBox=\"0 0 10 6\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M1 1L5 5L9 1\" stroke=\"%233E3E3E\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg>'); background-repeat: no-repeat; background-position: right 10px center;">
                {%- for country in localization.available_countries -%}
                  <option value="{{ country.iso_code }}" {%- if country.iso_code == localization.country.iso_code %} selected{% endif %}>
                    {{ country.name }} ({{ country.currency.iso_code }} {{ country.currency.symbol }})
                  </option>
                {%- endfor -%}
              </select>
            </div>
          {%- endif -%}
        </div>
      {%- endform -%}
    {%- endif -%}

    <div style="text-align: center; font-size: 10px; letter-spacing: 2px; color: #888; text-transform: uppercase;">
      &copy; {{ 'now' | date: '%Y' }} Tulsi Tales. All rights reserved.
    </div>
  </div>
</footer>
{% schema %}
{
  "name": "Ayus Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer Logo Image"
    }
  ]
}
{% endschema %}