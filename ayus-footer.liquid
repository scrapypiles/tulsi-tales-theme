<footer class="site-footer" style="padding: 100px 20px 40px; background-color: var(--color-background); color: var(--color-text); font-family: var(--font-body); border-top: 1px solid var(--color-border);">
  <!-- Top Columns (Strict Grid for Even Visual Spacing) -->
  <div style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: 1.2fr 1fr 1fr; gap: 60px;">
    
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'brand_info' %}
          <div {{ block.shopify_attributes }}>
            <div style="margin-bottom: 20px;">
              <a href="/">
                {% if block.settings.logo != blank %}
                  <img src="{{ block.settings.logo | img_url: '400x' }}" alt="{{ shop.name }}" style="max-width: {{ block.settings.logo_width }}px; height: auto;" />
                {% else %}
                  <img src="{{ 'logo.png' | asset_url }}" alt="Tulsi Tales Logo" style="max-width: {{ block.settings.logo_width }}px; height: auto;" />
                {% endif %}
              </a>
            </div>
            <div class="footer-rte" style="font-size: 14px; line-height: 2.2; color: #666; font-family: var(--font-body); letter-spacing: 0.05em; max-width: 380px; margin-top: 15px;">
              {{ block.settings.text }}
            </div>
            <style>.footer-rte p { margin: 0 0 10px 0; } .footer-rte a { color: var(--color-text); text-decoration: underline; text-underline-offset: 4px; } .footer-rte strong { font-weight: 600; color: var(--color-text); }</style>
          </div>

        {% when 'link_list' %}
          <div {{ block.shopify_attributes }}>
            <h4 style="font-family: var(--font-heading); font-weight: 500; letter-spacing: 3px; text-transform: uppercase; font-size: 15px; margin-bottom: 25px; color: var(--color-text);">{{ block.settings.heading }}</h4>
            <ul style="list-style: none; padding: 0; font-size: 12px; line-height: 2.5; letter-spacing: 1px; text-transform: uppercase;">
              {% assign footer_menu = block.settings.menu %}
              {% if footer_menu != blank and linklists[footer_menu] != empty and linklists[footer_menu].links.size > 0 %}
                {% for link in linklists[footer_menu].links %}
                  <li><a href="{{ link.url }}" style="color: var(--color-text); text-decoration: none;">{{ link.title }}</a></li>
                {% endfor %}
              {% else %}
                <li><a href="/collections/all" style="color: var(--color-text); text-decoration: none;">All Products</a></li>
                <li><a href="/pages/our-story" style="color: var(--color-text); text-decoration: none;">Our Story</a></li>
                <li><a href="/pages/contact" style="color: var(--color-text); text-decoration: none;">Contact Us</a></li>
              {% endif %}
            </ul>
          </div>

        {% when 'contact_newsletter' %}
          <div {{ block.shopify_attributes }}>
            <h4 style="font-family: var(--font-heading); font-weight: 500; letter-spacing: 3px; text-transform: uppercase; font-size: 15px; margin-bottom: 25px; color: var(--color-text);">{{ block.settings.heading }}</h4>
            
            <ul style="list-style: none; padding: 0; font-size: 12px; line-height: 2.5; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 30px;">
              {% if block.settings.email != blank %}
              <li style="margin-bottom: 8px;">
                <a href="mailto:{{ block.settings.email }}" style="color: #555; text-decoration: none; display: flex; align-items: center; gap: 12px;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                  {{ block.settings.email }}
                </a>
              </li>
              {% endif %}
              {% if block.settings.phone != blank %}
              <li style="margin-bottom: 8px;">
                <a href="tel:{{ block.settings.phone | remove: ' ' }}" style="color: #555; text-decoration: none; display: flex; align-items: center; gap: 12px;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                  {{ block.settings.phone }}
                </a>
              </li>
              {% endif %}
              {% if block.settings.instagram != blank %}
              <li style="margin-bottom: 8px;">
                <a href="https://instagram.com/{{ block.settings.instagram | remove: '@' }}" target="_blank" style="color: #555; text-decoration: none; display: flex; align-items: center; gap: 12px;">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                  {{ block.settings.instagram }}
                </a>
              </li>
              {% endif %}
            </ul>
            
            {% if block.settings.show_newsletter %}
            {% form 'customer', id: 'ContactFooter' %}
              <input type="hidden" name="contact[tags]" value="newsletter">
              
              <div style="display: flex; border-bottom: 1px solid var(--color-text); padding-bottom: 5px; max-width: 300px;">
                <input
                  type="email"
                  name="contact[email]"
                  value="{{ form.email }}"
                  aria-required="true"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  placeholder="{{ block.settings.newsletter_placeholder | escape }}"
                  style="border: none; background: transparent; width: 100%; font-family: var(--font-body); font-size: 13px; letter-spacing: 0.05em; color: var(--color-text); outline: none;"
                  required
                >
                <button type="submit" style="background: transparent; border: none; font-size: 20px; cursor: pointer; color: var(--color-text); padding: 5px 15px; position: relative; z-index: 10;">&rarr;</button>
              </div>
              {%- if form.posted_successfully? -%}
                <p style="font-size: 11px; color: green; margin-top: 10px; text-transform: uppercase; letter-spacing: 0.05em;">Thanks for subscribing!</p>
              {%- endif -%}
            {% endform %}
            {% endif %}
          </div>
      {% endcase %}
    {% else %}
      <!-- Fallback if blocks are deleted -->
      <div>
        <div style="margin-bottom: 20px;"><a href="/"><img src="{{ 'logo.png' | asset_url }}" alt="Tulsi Tales Logo" style="max-width: 180px; height: auto;" /></a></div>
        <div style="font-size: 14px; line-height: 2.2; color: #666; font-family: var(--font-body); letter-spacing: 0.05em; max-width: 380px; margin-top: 15px;">Rooted in eternal Ayurvedic wisdom. We craft pure, botanical formulations designed to bring holistic well-being, harmony, and natural balance to your daily rituals.</div>
      </div>
      <div>
        <h4 style="font-family: var(--font-heading); font-weight: 500; letter-spacing: 3px; text-transform: uppercase; font-size: 15px; margin-bottom: 25px; color: var(--color-text);">Explore</h4>
        <ul style="list-style: none; padding: 0; font-size: 12px; line-height: 2.5; letter-spacing: 1px; text-transform: uppercase;">
          <li><a href="/collections/all" style="color: var(--color-text); text-decoration: none;">All Products</a></li>
          <li><a href="/pages/our-story" style="color: var(--color-text); text-decoration: none;">Our Story</a></li>
          <li><a href="/pages/contact" style="color: var(--color-text); text-decoration: none;">Contact Us</a></li>
        </ul>
      </div>
      <div>
        <h4 style="font-family: var(--font-heading); font-weight: 500; letter-spacing: 3px; text-transform: uppercase; font-size: 15px; margin-bottom: 25px; color: var(--color-text);">Contact</h4>
        <ul style="list-style: none; padding: 0; font-size: 12px; line-height: 2.5; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 30px;">
          <li style="margin-bottom: 8px;"><a href="mailto:tulsitales@gmail.com" style="color: #555; text-decoration: none; display: flex; align-items: center; gap: 12px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>tulsitales@gmail.com</a></li>
          <li style="margin-bottom: 8px;"><a href="tel:+917832980384" style="color: #555; text-decoration: none; display: flex; align-items: center; gap: 12px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>+91 7832 980 384</a></li>
          <li style="margin-bottom: 8px;"><a href="https://instagram.com/tulsitalesofficial" target="_blank" style="color: #555; text-decoration: none; display: flex; align-items: center; gap: 12px;"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>@tulsitalesofficial</a></li>
        </ul>
      </div>
    {% endfor %}
  </div>

  <!-- Bottom Section: Policies, Divider, Copyright -->
  <div style="max-width: 1200px; margin: 60px auto 0; padding-top: 0; display: flex; flex-direction: column; align-items: center; gap: 20px;">
    
    <div style="display: flex; gap: 30px; justify-content: center; flex-wrap: wrap;">
      {% if section.settings.policy_menu != blank and linklists[section.settings.policy_menu].links.size > 0 %}
        {% for link in linklists[section.settings.policy_menu].links %}
          <a href="{{ link.url }}" style="font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none; color: #888;">{{ link.title }}</a>
        {% endfor %}
      {% else %}
        <a href="/pages/policy" style="font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none; color: #888;">Privacy Policy</a>
        <a href="/pages/terms" style="font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none; color: #888;">Terms of Service</a>
        <a href="/pages/refund" style="font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none; color: #888;">Refund Policy</a>
        <a href="/pages/shipping" style="font-size: 10px; letter-spacing: 1.5px; text-transform: uppercase; text-decoration: none; color: #888;">Shipping Policy</a>
      {% endif %}
    </div>

    {% if section.settings.show_divider %}
      <div style="width: 100%; border-top: 1px solid var(--color-border); margin: 10px 0;"></div>
    {% endif %}

    <div style="text-align: center; font-size: 10px; letter-spacing: 2px; color: #888; text-transform: uppercase;">
      &copy; {{ 'now' | date: '%Y' }} {{ section.settings.copyright_text | default: "TULSI TALES. ALL RIGHTS RESERVED." }}
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Ayus Footer",
  "settings": [
    {
      "type": "link_list",
      "id": "policy_menu",
      "label": "Policy Menu (Bottom Links)"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show Divider Line",
      "default": true
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "TULSI TALES. ALL RIGHTS RESERVED."
    }
  ],
  "blocks": [
    {
      "type": "brand_info",
      "name": "Brand Info",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Custom Logo (overrides default)"
        },
        {
          "type": "range",
          "id": "logo_width",
          "min": 100,
          "max": 300,
          "step": 10,
          "unit": "px",
          "label": "Logo Width",
          "default": 180
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Brand Description",
          "default": "<p>Rooted in eternal Ayurvedic wisdom. We craft pure, botanical formulations designed to bring holistic well-being, harmony, and natural balance to your daily rituals.</p>"
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Link Column",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Explore"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu (Leave empty for defaults)"
        }
      ]
    },
    {
      "type": "contact_newsletter",
      "name": "Contact & Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Contact"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email Address",
          "default": "tulsitales@gmail.com"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone Number",
          "default": "+91 7832 980 384"
        },
        {
          "type": "text",
          "id": "instagram",
          "label": "Instagram Handle",
          "default": "@tulsitalesofficial"
        },
        {
          "type": "checkbox",
          "id": "show_newsletter",
          "label": "Show Newsletter Form",
          "default": true
        },
        {
          "type": "text",
          "id": "newsletter_placeholder",
          "label": "Newsletter Placeholder",
          "default": "JOIN OUR NEWSLETTER"
        }
      ]
    }
  ]
}
{% endschema %}
