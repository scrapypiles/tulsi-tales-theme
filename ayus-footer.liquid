{% if section.settings.show_section %}
<footer class="site-footer tt-site-footer" style="padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px !important; background-color: var(--color-background); color: var(--color-text); font-family: var(--font-body); border-top: 1px solid var(--color-border);">
  <style>
    .tt-site-footer .tt-footer-shell {
      max-width: 1200px;
      margin: 0 auto;
    }
    .tt-site-footer .tt-footer-main {
      display: grid;
      grid-template-columns: minmax(0, 1.35fr) minmax(0, 0.85fr) minmax(0, 1fr);
      gap: 56px;
      align-items: start;
    }
    .tt-site-footer .tt-footer-brand-logo {
      display: inline-flex;
      align-items: center;
      justify-content: flex-start;
      margin-bottom: 30px;
    }
    .tt-site-footer .tt-footer-brand-copy,
    .tt-site-footer .tt-footer-newsletter-note,
    .tt-site-footer .footer-rte {
      font-size: 14px;
      line-height: 1.95;
      color: #6f6963;
      letter-spacing: 0.03em;
    }
    .tt-site-footer .footer-rte {
      max-width: 430px;
    }
    .tt-site-footer .footer-rte p {
      margin: 0 0 12px 0;
    }
    .tt-site-footer .footer-rte a {
      color: var(--color-text);
      text-decoration: underline;
      text-underline-offset: 4px;
    }
    .tt-site-footer .footer-rte strong {
      color: var(--color-text);
      font-weight: 600;
    }
    .tt-site-footer .tt-footer-column-title {
      margin: 0 0 22px 0;
      font-family: var(--font-heading);
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--color-text);
    }
    .tt-site-footer .tt-footer-link-list,
    .tt-site-footer .tt-footer-contact-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .tt-site-footer .tt-footer-link-list a {
      color: var(--color-text);
      text-decoration: none;
      font-size: 13px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      line-height: 1.6;
    }
    .tt-site-footer .tt-footer-contact-link {
      color: #5f5953;
      text-decoration: none;
      display: flex;
      align-items: flex-start;
      gap: 12px;
      font-size: 13px;
      line-height: 1.7;
      letter-spacing: 0.04em;
      word-break: break-word;
    }
    .tt-site-footer .tt-footer-contact-link svg {
      flex: 0 0 16px;
      margin-top: 3px;
    }
    .tt-site-footer .tt-footer-newsletter {
      margin-top: 26px;
      max-width: 320px;
    }
    .tt-site-footer .tt-footer-newsletter-note {
      margin: 0 0 12px 0;
      font-size: 12px;
      line-height: 1.8;
    }
    .tt-site-footer .tt-footer-newsletter-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid var(--color-text);
      padding-bottom: 2px;
      width: 100%;
      max-width: 100%;
      margin-bottom: 0;
      color: var(--color-text);
    }
    .tt-site-footer .tt-footer-newsletter-input {
      border: none;
      background: transparent;
      flex-grow: 1;
      outline: none;
      padding: 0;
      margin: 0;
      font-family: var(--font-body);
      font-size: 8px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--color-text);
      line-height: 1;
      height: 12px;
    }
    .tt-site-footer .tt-footer-newsletter-button {
      border: none;
      background: transparent;
      color: var(--color-text);
      font-size: 14px;
      line-height: 1;
      padding: 0;
      margin: 0;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      height: 12px;
      width: 20px;
    }
    .tt-site-footer .tt-footer-newsletter-input::placeholder {
      color: var(--color-text);
      opacity: 1;
    }
    .tt-site-footer .tt-footer-success {
      margin-top: 10px;
      font-size: 11px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-accent);
    }
    .tt-site-footer .tt-footer-meta {
      margin-top: 34px;
      padding-top: 14px;
    }
    .tt-site-footer .tt-footer-meta-row {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 12px;
    }
    .tt-site-footer .tt-footer-policy-links {
      display: flex;
      flex-wrap: wrap;
      gap: 10px 22px;
      align-items: center;
      justify-content: center;
    }
    .tt-site-footer .tt-footer-policy-links a {
      font-size: 9px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #978f87;
      text-decoration: none;
      line-height: 1.7;
    }
    .tt-site-footer .tt-footer-copyright {
      font-size: 6px !important;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #978f87;
      text-decoration: none;
      line-height: 1.35;
      text-align: center;
      max-width: 420px;
    }
    @media (max-width: 850px) {
      .tt-site-footer {
        padding-left: 16px !important;
        padding-right: 16px !important;
      }
      .tt-site-footer .tt-footer-main {
        grid-template-columns: 1fr 1fr;
        gap: 34px 24px;
      }
      .tt-site-footer .tt-footer-brand {
        grid-column: 1 / -1;
      }
      .tt-site-footer .tt-footer-brand-logo {
        margin-bottom: 25px;
      }
      .tt-site-footer .tt-footer-column-title {
        margin-bottom: 18px;
      }
      .tt-site-footer .tt-footer-link-list,
      .tt-site-footer .tt-footer-contact-list {
        gap: 12px;
      }
      .tt-site-footer .tt-footer-meta {
        margin-top: 28px;
        padding-top: 14px;
      }
      .tt-site-footer .tt-footer-meta-row {
        gap: 14px;
      }
      .tt-site-footer .tt-footer-policy-links {
        gap: 8px 16px;
      }
      .tt-site-footer .tt-footer-copyright {
        max-width: none;
      }
      .tt-site-footer .tt-footer-newsletter {
        max-width: none;
      }
    }
  </style>

  <div class="tt-footer-shell">
    <div class="tt-footer-main">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'brand_info' %}
            <div class="tt-footer-brand" {{ block.shopify_attributes }}>
              <a href="/" class="tt-footer-brand-logo">
                {% if block.settings.logo != blank %}
                  <img src="{{ block.settings.logo | img_url: '400x' }}" alt="{{ shop.name }}" style="max-width: {{ block.settings.logo_width }}px; height: auto;" loading="lazy">
                {% else %}
                  <img src="{{ 'logo.png' | asset_url }}" alt="Tulsi Tales Logo" style="max-width: {{ block.settings.logo_width }}px; height: auto;" loading="lazy">
                {% endif %}
              </a>
              <div class="footer-rte">
                {{ block.settings.text }}
              </div>
              {% for newsletter_block in section.blocks %}
                {% if newsletter_block.type == 'contact_newsletter' and newsletter_block.settings.show_newsletter %}
                  <div class="tt-footer-newsletter">
                    <p class="tt-footer-newsletter-note">Receive gentle notes on new arrivals, restocks, and rituals.</p>
                    {% form 'customer', id: 'ContactFooter', class: 'tt-footer-newsletter-form' %}
                      <input type="hidden" name="contact[tags]" value="newsletter">
                      <div class="tt-footer-newsletter-row">
                        <input
                          type="email"
                          name="contact[email]"
                          value="{{ form.email }}"
                          aria-required="true"
                          autocorrect="off"
                          autocapitalize="off"
                          autocomplete="email"
                          placeholder="{{ newsletter_block.settings.newsletter_placeholder | escape }}"
                          class="tt-footer-newsletter-input"
                          required
                        >
                        <button type="submit" class="tt-footer-newsletter-button" aria-label="Join newsletter">&rarr;</button>
                      </div>
                      {%- if form.posted_successfully? -%}
                        <p class="tt-footer-success">Thanks for subscribing.</p>
                      {%- endif -%}
                    {% endform %}
                  </div>
                  {% break %}
                {% endif %}
              {% endfor %}
            </div>

          {% when 'link_list' %}
            <div class="tt-footer-column tt-footer-links-column" {{ block.shopify_attributes }}>
              <h4 class="tt-footer-column-title">{{ block.settings.heading }}</h4>
              <ul class="tt-footer-link-list">
                {% assign footer_menu = block.settings.menu %}
                {% if footer_menu != blank and linklists[footer_menu] != empty and linklists[footer_menu].links.size > 0 %}
                  {% for link in linklists[footer_menu].links %}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {% endfor %}
                {% else %}
                  <li><a href="/collections/all">All Products</a></li>
                  <li><a href="/pages/our-story">Our Story</a></li>
                  <li><a href="/pages/contact">Contact Us</a></li>
                {% endif %}
              </ul>
            </div>

          {% when 'contact_newsletter' %}
            <div class="tt-footer-column tt-footer-contact-column" {{ block.shopify_attributes }}>
              <h4 class="tt-footer-column-title">{{ block.settings.heading }}</h4>
              <ul class="tt-footer-contact-list">
                {% if block.settings.email != blank %}
                  <li>
                    <a href="mailto:{{ block.settings.email }}" class="tt-footer-contact-link">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
                      <span>{{ block.settings.email }}</span>
                    </a>
                  </li>
                {% endif %}
                {% if block.settings.phone != blank %}
                  <li>
                    <a href="tel:{{ block.settings.phone | remove: ' ' }}" class="tt-footer-contact-link">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
                      <span>{{ block.settings.phone }}</span>
                    </a>
                  </li>
                {% endif %}
                {% if block.settings.instagram != blank %}
                  <li>
                    <a href="https://instagram.com/{{ block.settings.instagram | remove: '@' }}" target="_blank" rel="noopener" class="tt-footer-contact-link">
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                      <span>{{ block.settings.instagram }}</span>
                    </a>
                  </li>
                {% endif %}
              </ul>

            </div>
        {% endcase %}
      {% else %}
        <div class="tt-footer-brand">
          <a href="/" class="tt-footer-brand-logo"><img src="{{ 'logo.png' | asset_url }}" alt="Tulsi Tales Logo" style="max-width: 130px; height: auto;" loading="lazy"></a>
          <div class="footer-rte"><p>Rooted in eternal Ayurvedic wisdom. We craft pure, botanical formulations designed to bring holistic well-being, harmony, and natural balance to your daily rituals.</p></div>
        </div>
        <div class="tt-footer-column tt-footer-links-column">
          <h4 class="tt-footer-column-title">Explore</h4>
          <ul class="tt-footer-link-list">
            <li><a href="/collections/all">All Products</a></li>
            <li><a href="/pages/our-story">Our Story</a></li>
            <li><a href="/pages/contact">Contact Us</a></li>
          </ul>
        </div>
        <div class="tt-footer-column tt-footer-contact-column">
          <h4 class="tt-footer-column-title">Contact &amp; Join</h4>
          <ul class="tt-footer-contact-list">
            <li><a href="mailto:tulsitales@gmail.com" class="tt-footer-contact-link"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg><span>tulsitales@gmail.com</span></a></li>
            <li><a href="tel:+917832980384" class="tt-footer-contact-link"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg><span>+91 7832 980 384</span></a></li>
            <li><a href="https://instagram.com/tulsitalesofficial" target="_blank" rel="noopener" class="tt-footer-contact-link"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg><span>@tulsitalesofficial</span></a></li>
          </ul>
        </div>
      {% endfor %}
    </div>

    <div class="tt-footer-meta" {% if section.settings.show_divider %}style="border-top: 1px solid var(--color-border);"{% endif %}>
      <div class="tt-footer-meta-row">
        <div class="tt-footer-policy-links">
          {% if section.settings.policy_menu != blank and linklists[section.settings.policy_menu].links.size > 0 %}
            {% for link in linklists[section.settings.policy_menu].links %}
              <a href="{{ link.url }}">{{ link.title }}</a>
            {% endfor %}
          {% else %}
            <a href="/pages/policy">Privacy Policy</a>
            <a href="/pages/terms">Terms of Service</a>
            <a href="/pages/refund">Refund Policy</a>
            <a href="/pages/shipping">Shipping Policy</a>
          {% endif %}
        </div>

        <div class="tt-footer-copyright">
          &copy; {{ 'now' | date: '%Y' }} {{ section.settings.copyright_text | default: "TULSI TALES. ALL RIGHTS RESERVED." }}
        </div>
      </div>
    </div>
  </div>
</footer>
{% endif %}

{% schema %}
{
  "name": "Ayus Footer",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    },
    {
      "type": "link_list",
      "id": "policy_menu",
      "label": "Policy Menu (Bottom Links)"
    },
    {
      "type": "checkbox",
      "id": "show_divider",
      "label": "Show Divider Line",
      "default": true
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Text",
      "default": "TULSI TALES. ALL RIGHTS RESERVED."
    }
  ],
  "blocks": [
    {
      "type": "brand_info",
      "name": "Brand Info",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "logo",
          "label": "Custom Logo (overrides default)"
        },
        {
          "type": "range",
          "id": "logo_width",
          "min": 100,
          "max": 300,
          "step": 10,
          "unit": "px",
          "label": "Logo Width",
          "default": 130
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Brand Description",
          "default": "<p>Rooted in eternal Ayurvedic wisdom. We craft pure, botanical formulations designed to bring holistic well-being, harmony, and natural balance to your daily rituals.</p>"
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Link Column",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Explore"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu (Leave empty for defaults)"
        }
      ]
    },
    {
      "type": "contact_newsletter",
      "name": "Contact & Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Contact"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email Address",
          "default": "tulsitales@gmail.com"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "Phone Number",
          "default": "+91 7832 980 384"
        },
        {
          "type": "text",
          "id": "instagram",
          "label": "Instagram Handle",
          "default": "@tulsitalesofficial"
        },
        {
          "type": "checkbox",
          "id": "show_newsletter",
          "label": "Show Newsletter Form",
          "default": true
        },
        {
          "type": "text",
          "id": "newsletter_placeholder",
          "label": "Newsletter Placeholder",
          "default": "ENTER EMAIL TO JOIN NEWSLETTER"
        }
      ]
    }
  ]
}
{% endschema %}
