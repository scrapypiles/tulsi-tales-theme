<footer class="site-footer" style="padding: 100px 20px 40px; background-color: #F7F5F0; color: #2C2A29; font-family: var(--font-body); border-top: 1px solid #EAE5D9;">
  <div style="max-width: 1200px; margin: 0 auto; display: flex; flex-wrap: wrap; justify-content: space-between;">
    <div style="flex: 1; min-width: 250px; margin-bottom: 40px;">
      <div style="margin-bottom: 15px;">
        {%- assign logo_url = "tulsi-tales-logo.png" -%}
        {%- if logo_url != blank -%}
          <img src="{{ logo_url | asset_url }}" alt="Tulsi Tales Logo" style="max-width: 180px; height: auto;" />
        {%- elsif section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 120 }}" alt="Tulsi Tales Logo" style="max-width: 180px; height: auto;" />
        {%- else -%}
          <!-- Elegant minimal leaf SVG as fallback logo -->
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#2C2A29" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22c0-5 2-8 5-11-3 0-5 2-5 5 0-3-2-5-5-5 3 3 5 6 5 11z"></path>
            <path d="M12 22V12"></path>
          </svg>
        {%- endif -%}
      </div>
      <h4 style="font-family: var(--font-heading); font-weight: 300; letter-spacing: 3px; text-transform: uppercase; font-size: 14px; margin-bottom: 20px; color: #111;">Tulsi Tales</h4>
      <p style="font-size: 13px; line-height: 2; color: #555;">Rooted in Ayurvedic wisdom.<br>Crafted for modern rituals.</p>
    </div>
    <div style="flex: 1; min-width: 250px; margin-bottom: 40px;">
      <h4 style="font-family: var(--font-heading); font-weight: 300; letter-spacing: 2px; text-transform: uppercase; font-size: 11px; margin-bottom: 20px; color: #111;">Explore</h4>
      <ul style="list-style: none; padding: 0; font-size: 12px; line-height: 2.5; letter-spacing: 1px; text-transform: uppercase;">
        <li><a href="/collections/all" style="text-decoration: none; color: #555;">All Medicines</a></li>
        <li><a href="/pages/our-story" style="text-decoration: none; color: #555;">Our Story</a></li>
        <li><a href="/pages/contact" style="text-decoration: none; color: #555;">Contact Us</a></li>
      </ul>
    </div>
    <div style="flex: 1; min-width: 250px; margin-bottom: 40px;">
      <h4 style="font-family: var(--font-heading); font-weight: 300; letter-spacing: 2px; text-transform: uppercase; font-size: 11px; margin-bottom: 20px; color: #111;">Legal & Support</h4>
      <ul style="list-style: none; padding: 0; font-size: 12px; line-height: 2.5; letter-spacing: 1px; text-transform: uppercase;">
        <li><a href="/pages/terms" style="text-decoration: none; color: #555;">Terms of Service</a></li>
        <li><a href="/pages/policy" style="text-decoration: none; color: #555;">Privacy Policy</a></li>
        <li><a href="/pages/refund" style="text-decoration: none; color: #555;">Refund Policy</a></li>
        <li><a href="/pages/shipping" style="text-decoration: none; color: #555;">Shipping Policy</a></li>
      </ul>
    </div>
  </div>
  <div style="max-width: 1200px; margin: 40px auto 0; padding-top: 30px; border-top: 1px solid #EAE5D9; text-align: center; font-size: 10px; letter-spacing: 2px; color: #888; text-transform: uppercase;">
    &copy; {{ 'now' | date: '%Y' }} Tulsi Tales. All rights reserved.
  </div>
</footer>
{% schema %}
{
  "name": "Ayus Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer Logo Image"
    }
  ]
}
{% endschema %}