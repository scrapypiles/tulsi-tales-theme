

<!-- Top Announcement Bar -->
{% if section.settings.show_announcement %}
<div class="tt-announcement-bar">
  <p>{{ section.settings.announcement_text | escape }}</p>
</div>
{% endif %}

<header class="ayus-header">
  <div class="ayus-header-container">
    <!-- Mobile Hamburger Toggle -->
    <div class="ayus-mobile-toggle" onclick="openMobileMenu();">
      ☰
    </div>

    <!-- Desktop Nav Left -->
    

    <!-- Logo -->
    <div class="ayus-nav-left desktop-only">
      {% for link in linklists[section.settings.menu].links %}
        <div class="ayus-nav-item" style="position: relative; display: inline-block;">
          <a href="{{ link.url }}" class="ayus-nav-link" style="display: flex; align-items: center;">{{ link.title }}{% if link.links != blank %} <svg style="margin-left:5px; width:10px; height:10px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>{% endif %}</a>
          {% if link.links != blank %}
            <div class="ayus-dropdown" style="position: absolute; top: 100%; left: 0; background: var(--color-background); border: 1px solid var(--color-border); padding: 15px 20px; min-width: 200px; display: none; flex-direction: column; gap: 15px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); z-index: 100;">
              {% for childlink in link.links %}
                <a href="{{ childlink.url }}" style="text-transform: none; letter-spacing: 0.05em; margin: 0; padding: 5px 0;">{{ childlink.title }}</a>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
    <div class="ayus-logo">
      <a href="/" class="tt-logo-link">
        {% assign logo_url = section.settings.logo | default: 'tulsi-tales-logo.png' %}
        {% if logo_url %}
          <img src="{{ 'tulsi-tales-logo.png' | asset_url }}" alt="{{ shop.name }}" style="max-height: {{ section.settings.logo_height }}px; width: auto; display: block;">
        {% else %}
          {{ shop.name }}
        {% endif %}
      </a>
    </div>

    <!-- Nav Right (Desktop + Mobile Cart) -->
    <div class="ayus-nav-right">
      

      <a href="#" id="tt-search-toggle" class="tt-icon-link"><svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg></a>
      {% if customer %}
        <a href="{{ routes.account_url }}" class="ayus-account-link tt-icon-link desktop-only" title="Account"><svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></a>
      {% else %}
        <a href="{{ routes.account_login_url }}" class="ayus-account-link tt-icon-link desktop-only" title="Log In"><svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg></a>
      {% endif %}
      <a href="/cart" class="ayus-cart-link tt-icon-link"><svg viewBox="0 0 24 24" width="22" height="22" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path><line x1="3" y1="6" x2="21" y2="6"></line><path d="M16 10a4 4 0 0 1-8 0"></path></svg><span class="tt-cart-badge" id="tt-cart-badge">{{ cart.item_count }}</span></a>
    </div>
  </div>

  <!-- Dropdown Search Bar -->
  <div id="tt-search-bar" class="tt-search-bar-dropdown">
    <form action="{{ routes.search_url }}" method="get" class="tt-search-form">
      <input type="text" name="q" placeholder="Search remedies..." class="tt-search-input">
      <input type="hidden" name="options[prefix]" value="last">
      <button type="submit" class="tt-search-submit">Search</button>
      <button type="button" id="tt-search-close" class="tt-search-close">&times;</button>
    </form>
  </div>
</header>

<script>
  function openMobileMenu() {
    document.getElementById('ayus-mobile-drawer').classList.add('active');
    document.getElementById('ayus-mobile-overlay').classList.add('active');
    document.body.style.overflow = 'hidden';
  }
  function closeMobileMenu() {
    document.getElementById('ayus-mobile-drawer').classList.remove('active');
    document.getElementById('ayus-mobile-overlay').classList.remove('active');
    document.body.style.overflow = '';
  }
</script>


<div id="ayus-mobile-overlay" class="ayus-mobile-overlay" onclick="closeMobileMenu();"></div>
<!-- Mobile Navigation Drawer -->
<div id="ayus-mobile-drawer" class="ayus-mobile-drawer">
  <div class="ayus-mobile-drawer-header">
    <span class="tt-mobile-drawer-logo">Menu</span>
    <button class="ayus-mobile-drawer-close" onclick="closeMobileMenu();">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>
  
  <div class="ayus-mobile-drawer-body">
    <div class="tt-mobile-search-container">
      <form action="{{ routes.search_url }}" method="get" class="tt-mobile-search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input type="text" name="q" placeholder="Search remedies..." class="tt-mobile-search-input">
        <input type="hidden" name="options[prefix]" value="last">
      </form>
    </div>
    
    <nav class="ayus-mobile-nav">
      {% for link in linklists[section.settings.menu].links %}
        <div class="tt-mobile-nav-item">
          <a href="{{ link.url }}" class="tt-mobile-nav-link" style="display: flex; justify-content: space-between; align-items: center;">{{ link.title }}</a>
          {% if link.links != blank %}
            <div class="tt-mobile-dropdown" style="padding-left: 15px; border-left: 1px solid var(--color-border); margin-top: 10px; display: flex; flex-direction: column; gap: 10px;">
              {% for childlink in link.links %}
                <a href="{{ childlink.url }}" style="font-family: var(--font-body); font-size: 16px; color: #555; text-decoration: none;">{{ childlink.title }}</a>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      {% endfor %}
    </nav>
  </div>

  <div class="ayus-mobile-drawer-footer">
    <p style="font-size: 12px; color: #888; text-transform: uppercase; letter-spacing: 0.05em; margin: 0 0 10px 0;">Account</p>
    {% if customer %}
      <a href="{{ routes.account_url }}" class="tt-mobile-auth-link">My Account</a>
    {% else %}
      <a href="{{ routes.account_login_url }}" class="tt-mobile-auth-link">Sign In</a>
      <a href="{{ routes.account_register_url }}" class="tt-mobile-auth-link">Create Account</a>
    {% endif %}
  </div>
</div>


{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Main Menu",
      "default": "main-menu"
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement text",
      "default": "We guide with love. Reach us: Tulsitales@gmail.com | +91 7832980384"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_height",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Logo height",
      "default": 60
    }
  ]
}
{% endschema %}
