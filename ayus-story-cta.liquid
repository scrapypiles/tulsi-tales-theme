{%- style -%}
  #shopify-section-{{ section.id }} > section,
  #shopify-section-{{ section.id }} > div,
  #shopify-section-{{ section.id }} > header,
  #shopify-section-{{ section.id }} > footer {
    background-color: {{ section.settings.background_color | default: '#ffffff' }} !important;
    {% if section.settings.background_image != blank %}
      background-image: url('{{ section.settings.background_image | image_url: width: 2400 }}') !important;
      background-size: cover !important;
      background-position: {{ section.settings.background_position | default: 'center center' }} !important;
      background-repeat: no-repeat !important;
    {% endif %}
  }
{%- endstyle -%}

{% if section.settings.show_section %}


<section class="ayus-story-cta" style="padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px !important; text-align: center; background-color: #ffffff; border-bottom: 1px solid var(--color-border);">

    
    
  <div style="max-width: 800px; margin: 0 auto;">
    <{{ section.settings.heading_tag }} style="font-family: var(--font-heading); font-size: 36px; margin-bottom: 20px; color: var(--color-text);">{{ section.settings.heading }}</{{ section.settings.heading_tag }}>
    <div class="rte" style="font-family: var(--font-body); font-size: 14px; line-height: 1.8; color: #555; max-width: 600px; margin: 0 auto 40px auto;">
      {{ section.settings.text }}
    </div>
    {% if section.settings.btn_link != blank and section.settings.btn_label != blank %}
      <a href="{{ section.settings.btn_link }}" class="ayus-btn-outline" style="font-family: var(--font-body); text-transform: uppercase; letter-spacing: 0.15em; font-size: 11px; padding: 15px 30px; border: 1px solid var(--color-border); color: var(--color-text); text-decoration: none; display: inline-block;">
        {{ section.settings.btn_label }}
      </a>
    {% endif %}
  </div>
</section>

{% endif %}

{% schema %}
{
  "name": "Story Call to Action",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 100
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "select",
      "id": "background_position",
      "label": "Background image position",
      "options": [
        { "value": "center center", "label": "Center" },
        { "value": "center top", "label": "Top" },
        { "value": "center bottom", "label": "Bottom" },
        { "value": "left center", "label": "Left" },
        { "value": "right center", "label": "Right" }
      ],
      "default": "center center"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color"
    },
    {
      "type": "header",
      "content": "Layout & Styling"
    },
    {
      "type": "select",
      "id": "header_placement",
      "label": "Header Placement",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "border_placement",
      "label": "Border Placement",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" },
        { "value": "both", "label": "Top & Bottom" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading Size",
      "options": [
        { "value": "24px", "label": "Small" },
        { "value": "36px", "label": "Medium" },
        { "value": "48px", "label": "Large" }
      ],
      "default": "36px"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "layout_bg_color",
      "label": "Background Color",
      "default": "#FAF8F5"
    },
    {
      "type": "image_picker",
      "id": "custom_image",
      "label": "Insert Image"
    },
    
    { "type": "text", "id": "heading", "label": "Heading", "default": "Begin your journey" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Explore our curated collection of authentic Ayurvedic remedies.</p>" },
    { "type": "text", "id": "btn_label", "label": "Button Label", "default": "<p>Shop All</p>" },
    { "type": "url", "id": "btn_link", "label": "Button Link" }
  ],
  "presets": [{ "name": "Story Call to Action" }]
}
{% endschema %}
