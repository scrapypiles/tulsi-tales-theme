

<section class="ayus-story-cta" style="padding: 100px 20px; text-align: center; background-color: {{ section.settings.layout_bg_color | default: '#faf8f5' }};">

    
    
  <div style="max-width: 800px; margin: 0 auto;">
    <h2 style="font-family: var(--font-heading); font-size: 36px; margin-bottom: 20px; color: var(--color-text);">{{ section.settings.heading }}</h2>
    <div class="rte" style="font-family: var(--font-body); font-size: 14px; line-height: 1.8; color: #555; max-width: 600px; margin: 0 auto 40px auto;">
      {{ section.settings.text }}
    </div>
    {% if section.settings.btn_link != blank and section.settings.btn_label != blank %}
      <a href="{{ section.settings.btn_link }}" class="ayus-btn-outline" style="font-family: var(--font-body); text-transform: uppercase; letter-spacing: 0.15em; font-size: 11px; padding: 15px 30px; border: 1px solid var(--color-border); color: var(--color-text); text-decoration: none; display: inline-block;">
        {{ section.settings.btn_label }}
      </a>
    {% endif %}
  </div>
</section>
{% schema %}
{
  "name": "Story Call to Action",
  "settings": [
    {
      "type": "header",
      "content": "Layout & Styling"
    },
    {
      "type": "select",
      "id": "header_placement",
      "label": "Header Placement",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "border_placement",
      "label": "Border Placement",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "top", "label": "Top" },
        { "value": "bottom", "label": "Bottom" },
        { "value": "both", "label": "Top & Bottom" }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading Size",
      "options": [
        { "value": "24px", "label": "Small" },
        { "value": "36px", "label": "Medium" },
        { "value": "48px", "label": "Large" }
      ],
      "default": "36px"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "layout_bg_color",
      "label": "Background Color",
      "default": "#FAF8F5"
    },
    {
      "type": "image_picker",
      "id": "custom_image",
      "label": "Insert Image"
    },
    
    { "type": "text", "id": "heading", "label": "Heading", "default": "Begin your journey" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Explore our curated collection of authentic Ayurvedic remedies.</p>" },
    { "type": "text", "id": "btn_label", "label": "Button Label", "default": "<p>Shop All</p>" },
    { "type": "url", "id": "btn_link", "label": "Button Link" }
  ],
  "presets": [{ "name": "Story Call to Action" }]
}
{% endschema %}
