
<section class="ayus-policy-page" style="padding: 100px 20px; background-color: var(--color-background);">
  <div class="ayus-container" style="max-width: 800px; margin: 0 auto; background: #fff; padding: 60px 80px; border: 1px solid var(--color-border); box-shadow: 0 4px 20px rgba(0,0,0,0.03);">
    
    <div style="text-align: center; margin-bottom: 50px;">
      <span style="font-family: var(--font-body); text-transform: uppercase; letter-spacing: 0.15em; font-size: 10px; color: var(--color-accent); display: block; margin-bottom: 10px;">Legal</span>
      <h1 style="font-family: var(--font-heading); font-size: 36px; color: var(--color-text); margin: 0;">{{ page.title }}</h1>
    </div>

    <div class="rte" style="font-family: var(--font-body); font-size: 14px; line-height: 1.8; color: #444;">
      {{ page.content }}
    </div>

  </div>
</section>

<style>
  .ayus-policy-page .rte h1, .ayus-policy-page .rte h2, .ayus-policy-page .rte h3 {
    font-family: var(--font-heading);
    margin-top: 40px;
    margin-bottom: 15px;
    color: var(--color-text);
  }
  .ayus-policy-page .rte h2 { font-size: 22px; border-bottom: 1px solid var(--color-border); padding-bottom: 10px; }
  .ayus-policy-page .rte p { margin-bottom: 20px; }
  .ayus-policy-page .rte ul { margin-bottom: 20px; padding-left: 20px; }
  .ayus-policy-page .rte li { margin-bottom: 10px; }
  .ayus-policy-page .rte a { color: var(--color-accent); text-decoration: underline; }
  
  @media (max-width: 850px) {
    .ayus-policy-page .ayus-container { padding: 40px 20px !important; }
    .ayus-policy-page .rte h2 { font-size: 18px; }
    .ayus-policy-page .rte { font-size: 13px; }
  }
</style>

{% schema %}
{
  "name": "Policy Template",
  "settings": []
}
{% endschema %}
