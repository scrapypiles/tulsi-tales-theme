{% if section.settings.show_section %}

<section class="ayus-philosophy" style="background-color: #ffffff; padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px !important; text-align: center; border-top: 1px solid var(--color-border);">
  <div style="max-width: 700px; margin: 0 auto; display: flex; flex-direction: column; align-items: center;">
    <img src="{{ 'favicon.png' | asset_url }}" alt="Tulsi Tales Symbol" style="width: 40px; height: 40px; object-fit: contain; margin-bottom: 20px;">
    <h2 style="margin-top: 0; font-family: var(--font-heading); font-size: 36px; color: var(--color-text); margin-bottom: 25px; font-weight: normal;">{{ section.settings.heading | escape }}</h2>
    <p style="margin-bottom: 0; font-family: var(--font-body); font-size: 18px; color: #555; line-height: 1.8; font-style: italic;">“{{ section.settings.text | escape }}”</p>
  </div>
</section>


<style>
  #shopify-section-{{ section.id }} {
    background-color: #ffffff !important;
    margin-bottom: 0 !important;
    padding-bottom: 0 !important;
  }
</style>

{% endif %}

{% schema %}

{
  "name": "Ayus Philosophy",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "Padding bottom",
      "default": 80
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Promise"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "We declutter the path—making soulfully chosen remedies accessible and affordable. Grounded in tradition, purity, and purpose."
    }
  ],
  "presets": [
    {
      "name": "Ayus Philosophy"
    }
  ]
}
{% endschema %}
